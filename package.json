{
  "name": "player-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @player/web",
    "dev:desktop": "npm run dev --workspace @player/desktop",
    "dev:api": "npm run dev --workspace @player/api",
    "build:web": "npm run build --workspace @player/web",
    "build:desktop": "npm run build --workspace @player/desktop",
    "build:api": "npm run build --workspace @player/api",
    "dev:web+api": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:desktop+api": "concurrently -n api,desktop -c cyan,yellow \"npm run dev:api\" \"npm run dev:desktop\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*",
    "@rollup/rollup-linux-arm64-gnu": "*",
    "@rollup/rollup-darwin-x64": "*",
    "@rollup/rollup-darwin-arm64": "*",
    "@rollup/rollup-win32-x64-msvc": "*",
    "lightningcss-darwin-arm64": "*",
    "lightningcss-darwin-x64": "*",
    "lightningcss-linux-x64-gnu": "*",
    "lightningcss-linux-arm64-gnu": "*",
    "lightningcss-win32-x64-msvc": "*"
  }
}
