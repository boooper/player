generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model LikedArtist {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  source     String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SubsonicProfile {
  id              Int      @id @default(autoincrement())
  name            String
  url             String
  username        String
  password        String
  usePasswordAuth Boolean  @default(false)
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}