{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "naviarr",
  "version": "0.1.0",
  "identifier": "com.naviarr.app",
  "build": {
    "frontendDist": "http://localhost:3000",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Naviarr",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000 http://localhost:5173 https:; img-src 'self' data: https: http://localhost:*; media-src 'self' blob: http://localhost:* https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../build/**/*": "build/",
      "../node_modules/better-sqlite3/**/*": "node_modules/better-sqlite3/",
      "../node_modules/bindings/**/*": "node_modules/bindings/",
      "../node_modules/file-uri-to-path/**/*": "node_modules/file-uri-to-path/",
      "../node_modules/@prisma/client/**/*": "node_modules/@prisma/client/",
      "../node_modules/@prisma/adapter-better-sqlite3/**/*": "node_modules/@prisma/adapter-better-sqlite3/",
      "../node_modules/@prisma/engines/**/*": "node_modules/@prisma/engines/",
      "../node_modules/prisma/**/*": "node_modules/prisma/",
      "../prisma/schema.prisma": "prisma/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
