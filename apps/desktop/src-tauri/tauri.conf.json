{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "naviarr",
  "version": "0.1.0",
  "identifier": "com.naviarr.player",
  "build": {
    "frontendDist": "../../web/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn --cwd ../.. dev:web+api"
  },
  "app": {
    "windows": [
      {
        "title": "Naviarr",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8787 http://localhost:8787 http://localhost:5173 https:; img-src 'self' data: https: http://localhost:* http://*:*; media-src 'self' blob: http://localhost:* http://*:* https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
