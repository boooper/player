generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Setting {
  key   String @id
  value String
}

model Profile {
  id              Int      @id @default(autoincrement())
  name            String
  url             String
  username        String
  password        String
  usePasswordAuth Boolean  @default(false)
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LikedArtist {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  source     String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
